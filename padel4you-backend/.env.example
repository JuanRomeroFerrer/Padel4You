# ===== BASE DE DATOS =====
DATABASE_URL=postgresql://usuario:contraseña@host:5432/padel4you_db

# ===== SERVIDOR =====
NODE_ENV=production
PORT=3000
API_URL=https://tu-app.railway.app

# ===== SEGURIDAD =====
JWT_SECRET=tu-secreto-super-seguro-cambiar-en-produccion
JWT_EXPIRE=7d
BCRYPT_ROUNDS=12

# ===== CORS =====
CORS_ORIGIN=https://tu-web.railway.app,https://tu-dominio.com

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== RESERVAS =====
HOLD_DURATION_MINUTES=3
MAX_RESERVATIONS_PER_USER=5

# ===== EMAIL (Opcional para notificaciones) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-app

# ===== LOGGING =====
LOG_LEVEL=info
